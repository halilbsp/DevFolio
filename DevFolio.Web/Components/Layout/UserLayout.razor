@inherits LayoutComponentBase
@namespace DevFolio.Web.Components.Layout

<HeadContent>
    <title>DevFolio | Kullanıcı Paneli</title>
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-surface": "#ffffff",
              "outline-variant": "#484847",
              "error": "#ff716c",
              "secondary": "#a68cff",
              "surface-bright": "#2c2c2c",
              "surface-container-lowest": "#000000",
              "on-surface-variant": "#adaaaa",
              "surface-dim": "#0e0e0e",
              "primary": "#81ecff",
              "surface-container-highest": "#262626",
              "surface-container-high": "#20201f",
              "surface-container": "#1a1a1a",
              "primary-container": "#00e3fd"
            },
            fontFamily: {
              "headline": ["Space Grotesk"],
              "body": ["Inter"]
            }
          }
        }
      }
    </script>
    <style>
        body { background-color: #0e0e0e; color: #ffffff; font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</HeadContent>

<div class="flex min-h-screen selection:bg-primary selection:text-on-primary">
    
    <aside class="fixed left-0 top-0 h-full flex flex-col bg-[#131313] shadow-[0px_24px_48px_rgba(0,0,0,0.4)] z-50 w-64 border-r border-white/5">
        <div class="p-8 flex items-center gap-3">
            <div class="w-10 h-10 rounded bg-gradient-to-br from-secondary to-[#7e51ff] flex items-center justify-center">
                <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">terminal</span>
            </div>
            <div>
                <h2 class="font-['Space_Grotesk'] font-bold text-[#a68cff] tracking-tight">Portfolyo Yönetimi</h2>
                <p class="text-[10px] text-neutral-400 uppercase tracking-widest">Düzenleme Modu</p>
            </div>
        </div>
        
        <nav class="flex-1 mt-4">
            <a href="/user/dashboard#kimlik" class="flex items-center gap-4 px-8 py-4 text-[#a68cff] font-bold bg-[#1a1a1a] transition-colors border-r-2 border-[#a68cff]">
                <span class="material-symbols-outlined" data-icon="edit_note">edit_note</span>
                <span class="font-['Space_Grotesk'] font-medium text-base">Kimlik & Bio</span>
            </a>
            <a href="/user/dashboard#projeler" class="flex items-center gap-4 px-8 py-4 text-neutral-400 hover:text-white transition-colors opacity-80 hover:opacity-100">
                <span class="material-symbols-outlined" data-icon="grid_view">grid_view</span>
                <span class="font-['Space_Grotesk'] font-medium text-base">Projeler (CRUD)</span>
            </a>
            <a href="/user/dashboard#yetenekler" class="flex items-center gap-4 px-8 py-4 text-neutral-400 hover:text-white transition-colors opacity-80 hover:opacity-100">
                <span class="material-symbols-outlined" data-icon="psychology">psychology</span>
                <span class="font-['Space_Grotesk'] font-medium text-base">Yetenekler</span>
            </a>
            <a href="/user/dashboard#gorsel" class="flex items-center gap-4 px-8 py-4 text-neutral-400 hover:text-white transition-colors opacity-80 hover:opacity-100">
                <span class="material-symbols-outlined" data-icon="image">image</span>
                <span class="font-['Space_Grotesk'] font-medium text-base">Görsel Medya</span>
            </a>
        </nav>
        
        <div class="p-8 mt-auto border-t border-white/5">
            <div class="flex items-center gap-3">
                <img class="w-10 h-10 rounded-full grayscale hover:grayscale-0 transition-all cursor-pointer" src="/uploads/default.jpg" onerror="this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuBaXnf6IaW7mka5-KeXY8SFyjqbQ8G4TTFy_9MpsuaPIJjVtDZjWkmuACYEhiaOR1PwbF2R8qPAau1ZJ8KuQhgjEZ9ogxsakOnQUMegh-B3YnQlP8JnmAXy8RpUjVB2IPzJ-MGILaYW0OH31Y1RlI2JkW46Lsy8bACQrNo699neav7eRSHKkYJ-WN7aTHFX6oSu8QuN0dobM2FeglR-I8dLYoYlUXGKi6I4q08v0NG1rKJeXogy-LgxAu1oNi7LrsCC6et4n5PrsC8'" />
                <div>
                    <p class="text-sm font-medium text-white">Sistem Mimarı</p>
                    <p class="text-[10px] text-primary">Kurucu Üye</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="ml-64 flex-1 p-12 bg-[#0e0e0e] h-screen overflow-y-auto">
        @Body
    </main>
    
</div>