@page "/admin/skills"
@rendermode InteractiveServer
@layout DevFolio.Web.Components.Admin.AdminLayout
@using DevFolio.Infrastructure.Context
@using DevFolio.Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<header class="mb-12">
    <h2 class="font-headline text-4xl font-bold tracking-tight text-white">Yetenek Havuzu</h2>
    <p class="text-on-surface-variant mt-2 font-medium text-sm">Platformdaki global teknoloji ve yetenek etiketlerini yönetin.</p>
</header>

<div class="bg-surface-container-low rounded-xl overflow-hidden border border-white/5 shadow-lg flex flex-col">
    <div class="px-8 py-6 flex justify-between items-center bg-surface-container">
        <h3 class="font-headline font-bold text-lg text-white">GLOBAL YETENEK DİZİNİ</h3>
    </div>
    
    <div class="overflow-x-auto flex-1">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="text-[10px] tracking-[0.15em] text-on-surface-variant uppercase bg-surface-container/50">
                    <th class="px-8 py-4 font-semibold">Yetenek Adı</th>
                    <th class="px-4 py-4 font-semibold">Sahibi (Geliştirici)</th>
                    <th class="px-4 py-4 font-semibold">Renk Sınıfı</th>
                    <th class="px-8 py-4 font-semibold text-right">Aksiyonlar</th>
                </tr>
            </thead>
            <tbody class="text-sm divide-y divide-white/5">
                @if (allSkills == null)
                {
                    <tr><td colspan="4" class="px-8 py-10 text-center"><div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-secondary mx-auto"></div></td></tr>
                }
                else if (!allSkills.Any())
                {
                    <tr><td colspan="4" class="px-8 py-10 text-center text-on-surface-variant">Sistemde hiç yetenek bulunmuyor.</td></tr>
                }
                else
                {
                    @foreach (var skill in allSkills)
                    {
                        <tr class="hover:bg-surface-container-highest/30 transition-colors">
                            <td class="px-8 py-4 font-bold @skill.ColorClass">@skill.Name</td>
                            <td class="px-4 py-4 text-white">@skill.Portfolio?.FullName</td>
                            <td class="px-4 py-4 text-on-surface-variant font-mono text-xs">@skill.ColorClass</td>
                            <td class="px-8 py-4 text-right">
                                <button @onclick="() => DeleteSkill(skill)" class="p-2 hover:bg-error/20 text-on-surface-variant hover:text-error rounded-lg transition-colors">
                                    <span class="material-symbols-outlined text-lg">delete</span>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Skill>? allSkills;

    protected override async Task OnInitializedAsync()
    {
        await LoadSkills();
    }

    private async Task LoadSkills()
    {
        allSkills = await Db.Skills
            .Include(s => s.Portfolio)
            .OrderByDescending(s => s.Id)
            .ToListAsync();
    }

    private async Task DeleteSkill(Skill skill)
    {
        Db.Skills.Remove(skill);
        await Db.SaveChangesAsync();
        await LoadSkills(); // Listeyi yenile
    }
}