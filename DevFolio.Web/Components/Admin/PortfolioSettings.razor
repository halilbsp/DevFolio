@page "/admin/portfolio-settings"
@rendermode InteractiveServer
@layout AdminLayout

<header class="mb-12">
    <h2 class="font-headline text-4xl font-bold tracking-tight text-white">Sistem Ayarları</h2>
    <p class="text-on-surface-variant mt-2 font-medium text-sm">Platformun genel kurallarını, varsayılan temaları ve limitleri yapılandırın.</p>
</header>

<div class="bg-surface-container-low p-8 rounded-xl border border-white/5 shadow-lg min-h-[400px] flex items-center justify-center">
    <div class="text-center">
        <span class="material-symbols-outlined text-6xl text-primary-container opacity-50 mb-4">settings_accessibility</span>
        <h3 class="text-xl font-bold text-white mb-2">Konfigürasyon Modülü</h3>
        <p class="text-on-surface-variant">Bu modül yakında devreye alınacak...</p>
    </div>
</div>