@page "/{Username}"
@using DevFolio.Domain.Entities
@using DevFolio.Application.Interfaces
@inject IPortfolioRepository PortfolioRepo

@if (isLoading)
{
    <div class="min-h-screen flex items-center justify-center bg-surface-dim">
        <div class="animate-spin rounded-full h-16 w-16 border-t-2 border-b-2 border-primary"></div>
    </div>
}
else if (CurrentPortfolio == null)
{
    <div class="min-h-screen flex flex-col items-center justify-center bg-surface-dim text-on-surface">
        <h1 class="text-9xl font-headline font-bold text-primary mb-4 text-gradient-primary">404</h1>
        <p class="text-xl text-on-surface-variant">Bu geliştiriciye ait bir portfolyo bulunamadı. 😢</p>
        <a href="/" class="mt-8 px-6 py-3 bg-surface-container-highest border border-white/10 text-white font-headline rounded-xl hover:bg-primary/20 transition-all">
            Ana Sayfaya Dön
        </a>
    </div>
}
else
{
    <PageTitle>@CurrentPortfolio.FullName | @CurrentPortfolio.JobTitle</PageTitle>

    <nav class="sticky top-0 z-50 flex justify-between items-center px-6 md:px-12 py-6 w-full max-w-screen-2xl mx-auto bg-surface-dim/80 backdrop-blur-xl border-b border-white/5">
        <div class="flex items-center gap-2">
            <span class="text-[#81ecff] font-black italic font-headline text-xl tracking-tighter">DevFolio</span>
        </div>
        <div class="hidden md:flex items-center space-x-8">
            <a class="font-headline uppercase tracking-widest text-sm text-primary border-b border-primary transition-all" href="#projects">Projeler</a>
            <a class="font-headline uppercase tracking-widest text-sm text-neutral-400 hover:text-primary transition-all" href="#skills">Yetenekler</a>
            <a class="font-headline uppercase tracking-widest text-sm text-neutral-400 hover:text-primary transition-all" href="#contact">İletişim</a>
        </div>
        <div class="flex items-center gap-6">
            <a href="mailto:iletisim@devfolio.com" class="bg-gradient-to-br from-primary to-primary-container text-on-primary-fixed font-headline font-bold px-6 py-2 rounded-lg hover:scale-105 transition-transform shadow-[0_0_20px_rgba(129,236,255,0.2)]">
                İletişime Geç
            </a>
        </div>
    </nav>

    <main class="max-w-screen-2xl mx-auto px-6 md:px-12 pb-32">
        <section class="min-h-[80vh] flex flex-col-reverse md:flex-row items-center justify-between gap-12 py-20">
            <div class="flex-1 space-y-8 z-10">
                <div class="inline-flex items-center px-3 py-1 rounded-full bg-surface-container-highest border border-outline-variant/20">
                    <span class="w-2 h-2 rounded-full bg-primary mr-2 animate-pulse"></span>
                    <span class="text-xs font-label uppercase tracking-widest text-on-surface-variant">Yeni projelere açık</span>
                </div>
                <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tight leading-[1.1] text-white">
                    @CurrentPortfolio.FullName <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">@CurrentPortfolio.JobTitle</span>
                </h1>
                <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl leading-relaxed">
                    @CurrentPortfolio.Bio
                </p>
                <div class="flex flex-wrap gap-4 pt-4">
                    <a href="#projects" class="px-8 py-4 bg-primary text-on-primary-fixed font-headline font-bold rounded-xl shadow-[0px_10px_30px_rgba(129,236,255,0.2)] hover:scale-[1.02] transition-transform">
                        Projeleri İncele
                    </a>
                </div>
            </div>
            
            <div class="relative flex-1 flex justify-end items-center">
                <div class="relative w-72 h-72 md:w-[450px] md:h-[450px]">
                    <div class="absolute inset-0 bg-gradient-to-tr from-primary/30 to-secondary/30 rounded-[3rem] rotate-6 blur-3xl"></div>
                    <img class="relative w-full h-full object-cover rounded-[2.5rem] border border-white/10 shadow-2xl grayscale hover:grayscale-0 transition-all duration-700" src="@CurrentPortfolio.ProfileImageUrl" onerror="this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuBaXnf6IaW7mka5-KeXY8SFyjqbQ8G4TTFy_9MpsuaPIJjVtDZjWkmuACYEhiaOR1PwbF2R8qPAau1ZJ8KuQhgjEZ9ogxsakOnQUMegh-B3YnQlP8JnmAXy8RpUjVB2IPzJ-MGILaYW0OH31Y1RlI2JkW46Lsy8bACQrNo699neav7eRSHKkYJ-WN7aTHFX6oSu8QuN0dobM2FeglR-I8dLYoYlUXGKi6I4q08v0NG1rKJeXogy-LgxAu1oNi7LrsCC6et4n5PrsC8'" />
                </div>
            </div>
        </section>

        <section id="skills" class="py-16 border-y border-white/5 relative">
            <div class="absolute inset-0 bg-primary/5 blur-3xl rounded-full"></div>
            <div class="relative flex flex-wrap justify-center gap-6 md:gap-12">
                @if(CurrentPortfolio.Skills != null && CurrentPortfolio.Skills.Any())
                {
                    @foreach (var skill in CurrentPortfolio.Skills)
                    {
                        <div class="flex items-center gap-3 group">
                            <span class="@skill.ColorClass font-headline font-bold text-xl md:text-2xl group-hover:scale-110 transition-transform">@skill.Name</span>
                            <div class="h-px w-6 bg-outline-variant group-hover:w-12 transition-all"></div>
                        </div>
                    }
                }
            </div>
        </section>

        <section class="py-32" id="projects">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
                <div>
                    <h2 class="font-headline text-4xl font-bold mb-4 text-white">Öne Çıkan Projeler</h2>
                    <p class="text-on-surface-variant max-w-xl text-lg">Geliştirdiğim sistemler, mimariler ve canlıya alınan ürünler.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @if(CurrentPortfolio.Projects != null && CurrentPortfolio.Projects.Any())
                {
                    @foreach (var project in CurrentPortfolio.Projects)
                    {
                        <div class="bg-[#131313] border border-white/5 rounded-2xl overflow-hidden group hover:border-white/10 hover:-translate-y-1 transition-all duration-500 shadow-xl">
                            
                            <div class="h-56 overflow-hidden relative bg-black">
                                @if(!string.IsNullOrEmpty(project.ImageUrl))
                                {
                                    <img class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" src="@project.ImageUrl" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-surface-container-highest to-black">
                                        <span class="material-symbols-outlined text-6xl text-on-surface-variant opacity-20">deployed_code</span>
                                    </div>
                                }
                                <div class="absolute inset-0 bg-gradient-to-t from-[#131313] to-transparent opacity-60"></div>
                            </div>

                            <div class="p-8">
                                <div class="flex justify-between items-start mb-4">
                                    <h3 class="font-headline text-2xl font-bold text-white tracking-tight">@project.Title</h3>
                                    <div class="flex gap-3 text-on-surface-variant">
                                        @if(!string.IsNullOrEmpty(project.GithubUrl)){
                                            <a href="@project.GithubUrl" target="_blank" class="hover:text-white transition-colors"><span class="material-symbols-outlined text-[22px]">code</span></a>
                                        }
                                        @if(!string.IsNullOrEmpty(project.LiveUrl)){
                                            <a href="@project.LiveUrl" target="_blank" class="hover:text-white transition-colors"><span class="material-symbols-outlined text-[22px]">open_in_new</span></a>
                                        }
                                    </div>
                                </div>
                                
                                <p class="text-on-surface-variant text-sm leading-relaxed line-clamp-2 mb-8 h-10">
                                    @project.Description
                                </p>
                                
                                <div class="flex flex-wrap gap-2">
                                    @if(!string.IsNullOrEmpty(project.Tags))
                                    {
                                        var tags = project.Tags.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
                                        @foreach (var tag in tags)
                                        {
                                            <span class="px-3 py-1 text-xs font-medium rounded bg-transparent border border-primary/20 text-[#81ecff]">
                                                @tag.Trim()
                                            </span>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-span-full py-20 text-center border border-white/5 rounded-2xl bg-surface-container-low">
                        <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-4">construction</span>
                        <p class="text-on-surface-variant text-lg">Bu geliştirici henüz bir proje sergilemiyor.</p>
                    </div>
                }
            </div>
        </section>
    </main>

    <div class="fixed bottom-8 right-8 z-40 hidden md:block">
        <div class="bg-[#131313] p-4 rounded-full flex items-center gap-4 border border-white/10 shadow-2xl backdrop-blur-xl">
            <div class="w-10 h-10 rounded-full overflow-hidden border border-white/20">
                <img class="w-full h-full object-cover" src="@CurrentPortfolio.ProfileImageUrl" onerror="this.src='https://lh3.googleusercontent.com/aida-public/AB6AXuBaXnf6IaW7mka5-KeXY8SFyjqbQ8G4TTFy_9MpsuaPIJjVtDZjWkmuACYEhiaOR1PwbF2R8qPAau1ZJ8KuQhgjEZ9ogxsakOnQUMegh-B3YnQlP8JnmAXy8RpUjVB2IPzJ-MGILaYW0OH31Y1RlI2JkW46Lsy8bACQrNo699neav7eRSHKkYJ-WN7aTHFX6oSu8QuN0dobM2FeglR-I8dLYoYlUXGKi6I4q08v0NG1rKJeXogy-LgxAu1oNi7LrsCC6et4n5PrsC8'" />
            </div>
            <div class="pr-4">
                <p class="text-[10px] font-label text-primary uppercase font-bold tracking-widest flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span> Sistem Durumu
                </p>
                <p class="text-xs font-medium text-white">Geliştirmeye Devam Ediyor</p>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Username { get; set; } = string.Empty;

    private Portfolio? CurrentPortfolio;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // 1. Adım: Veritabanına gidiyoruz ve URL'den gelen ismi çekiyoruz! 🕵️‍♂️🗄️
        CurrentPortfolio = await PortfolioRepo.GetPortfolioByUsernameAsync(Username);
        
        // 2. Adım: Havalı bir yükleme hissi vermek için (SaaS projelerinde güzel durur)
        await Task.Delay(300); 
        
        isLoading = false;
    }
}